{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50"
  },
  "permissions": {
    "allow": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/joe/.nvm/versions/node/v22.15.1/bin/node /home/joe/github/xrp-ticker/.claude/hooks/session-start.cjs",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/joe/.nvm/versions/node/v22.15.1/bin/node /home/joe/github/xrp-ticker/.claude/hooks/context-injector.cjs",
            "timeout": 3000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/joe/.nvm/versions/node/v22.15.1/bin/node /home/joe/github/xrp-ticker/.claude/hooks/bash-validator.cjs",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/joe/.nvm/versions/node/v22.15.1/bin/node /home/joe/github/xrp-ticker/.claude/hooks/file-validator.cjs",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/joe/.nvm/versions/node/v22.15.1/bin/node /home/joe/github/xrp-ticker/.claude/hooks/post-edit.cjs",
            "timeout": 3000,
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/joe/.nvm/versions/node/v22.15.1/bin/node /home/joe/github/xrp-ticker/.claude/hooks/gate-monitor.cjs",
            "timeout": 3000,
            "async": true
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/joe/.nvm/versions/node/v22.15.1/bin/node /home/joe/github/xrp-ticker/.claude/hooks/agent-tracker.cjs",
            "timeout": 3000,
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/joe/.nvm/versions/node/v22.15.1/bin/node /home/joe/github/xrp-ticker/.claude/hooks/agent-synthesizer.cjs",
            "timeout": 3000,
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/joe/.nvm/versions/node/v22.15.1/bin/node /home/joe/github/xrp-ticker/.claude/hooks/pre-compact.cjs",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/joe/.nvm/versions/node/v22.15.1/bin/node /home/joe/github/xrp-ticker/.claude/hooks/dod-verifier.cjs",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/joe/.nvm/versions/node/v22.15.1/bin/node /home/joe/github/xrp-ticker/.claude/hooks/session-end.cjs",
            "timeout": 5000,
            "async": true
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/joe/.nvm/versions/node/v22.15.1/bin/node /home/joe/github/xrp-ticker/.claude/hooks/worktree-lifecycle.cjs",
            "timeout": 3000,
            "async": true
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/joe/.nvm/versions/node/v22.15.1/bin/node /home/joe/github/xrp-ticker/.claude/hooks/worktree-lifecycle.cjs",
            "timeout": 3000,
            "async": true
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/joe/.nvm/versions/node/v22.15.1/bin/node /home/joe/github/xrp-ticker/.claude/hooks/config-watcher.cjs",
            "timeout": 2000,
            "async": true
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/joe/.nvm/versions/node/v22.15.1/bin/node /home/joe/github/xrp-ticker/.claude/hooks/teammate-idle.cjs",
            "timeout": 5000
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/joe/.nvm/versions/node/v22.15.1/bin/node /home/joe/github/xrp-ticker/.claude/hooks/task-completed.cjs",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "sentient": {
    "models": {
      "default": "sonnet",
      "planning": "sonnet",
      "exploration": "haiku",
      "security": "opus"
    },
    "thinking": {
      "maxTokens": 16000,
      "extendedFor": [
        "architecture",
        "security",
        "complex-refactoring"
      ]
    },
    "session": {
      "autoName": true,
      "maxBudgetUsd": null
    },
    "vision": {
      "enabled": true,
      "screenshotOnError": true
    },
    "mcpServers": [
      "context7",
      "github",
      "memory",
      "puppeteer"
    ]
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  }
}
